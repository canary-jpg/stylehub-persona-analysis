    create  table
      "stylehub"."main"."fct_order_items__dbt_tmp"
  
    as (
      

with orders as (
    select * from "stylehub"."main"."stg_orders"
),

products as (
    select * from "stylehub"."main"."stg_products"
),

clusters as (
    select * from "stylehub"."main"."rpt_behavioral_clusters"
),

--parse JSON products array into individual items
--Note: DuckDB can handle JSON parsing
order_items_parsed as (
    select 
        o.order_id,
        o.customer_id,
        o.ordered_at,
        o.total,
        o.num_items,
        o.returned,

        --parsing products JSON array
        --the products column contains JSON like: ["P00001", "P00002", "P00003"]
        unnest(json_extract_string(o.products, '$')) as product_id
    from orders o 
    where o.products is not null 
),

--join with products details
order_items_enriched as (
    select 
        oi.order_id,
        oi.customer_id,
        oi.ordered_at,
        oi.product_id,

        --product details
        p.product_name,
        p.category,
        p.brand,
        p.base_price,

        --order context
        oi.total as order_total,
        oi.num_items as items_in_order,
        oi.returned as order_returned,

        --customer context
        cl.cluster_name,
        cl.persona_hidden
    from order_items_parsed oi 
    left join products p on oi.product_id = p.product_id 
    left join clusters cl on oi.customer_id = cl.customer_id 

)

select * from order_items_enriched
    );
  
  
