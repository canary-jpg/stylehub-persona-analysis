[0m14:40:54.881161 [debug] [Thread-1 (]: On model.stylehub_dbt.fct_order_items: /* {"app": "dbt", "dbt_version": "1.11.4", "profile_name": "stylehub", "target_name": "dev", "node_id": "model.stylehub_dbt.fct_order_items"} */

  
    
    

    create  table
      "stylehub"."main"."fct_order_items__dbt_tmp"
  
    as (
      

with orders as (
    select * from "stylehub"."main"."stg_orders"
),

products as (
    select * from "stylehub"."main"."stg_products"
),

clusters as (
    select * from "stylehub"."main"."rpt_behavioral_clusters"
),

-- Assign likely products to orders based on value and num_items
-- This creates a realistic product mix per order
order_items_generated as (
    select
        o.order_id,
        o.customer_id,
        o.ordered_at,
        o.total,
        o.num_items,
        o.returned,
        
        -- Generate item number (1 to num_items)
        unnest(generate_series(1, o.num_items)) as item_number,
        
        -- Assign product based on order total and item position
        -- Higher value orders get higher-priced products
        case
            when o.total / o.num_items >= 100 then 
                (select product_id from products where base_price >= 100 order by random() limit 1)
            when o.total / o.num_items >= 50 then
                (select product_id from products where base_price >= 50 and base_price < 100 order by random() limit 1)
            when o.total / o.num_items >= 30 then
                (select product_id from products where base_price >= 30 and base_price < 50 order by random() limit 1)
            else
                (select product_id from products where base_price < 30 order by random() limit 1)
        end as product_id
        
    from orders o
),

-- Join with product details
order_items_enriched as (
    select
        oi.order_id,
        oi.customer_id,
        oi.ordered_at,
        oi.product_id,
        
        -- Product details
        p.product_name,
        p.category,
        p.brand,
        p.base_price,
        
        -- Order context
        oi.total as order_total,
        oi.num_items as items_in_order,
        oi.returned as order_returned,
        
        -- Customer context
        cl.cluster_name,
        cl.persona_hidden
        
    from order_items_generated oi
    left join products p on oi.product_id = p.product_id
    left join clusters cl on oi.customer_id = cl.customer_id
)

select * from order_items_enriched
    );
  
  
