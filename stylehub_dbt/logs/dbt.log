    create  table
      "stylehub"."main"."rpt_customer_journey__dbt_tmp"
  
    as (
      

with customers as (
    select * from "stylehub"."main"."stg_customers"
),

sessions as (
    select * from "stylehub"."main"."stg_sessions"
),

orders as (
    select * from "stylehub"."main"."stg_orders"
),

clusters as (
    select * from "stylehub"."main"."rpt_behavioral_clusters"
),

--combine all events into timeline
all_events as (
    select 
        s.customer_id,
        s.session_start_at as event_timestamp,
        'Session' as event_type,
        s.num_products_viewed as event_value,
        s.purchased as led_to_purchase,
    from sessions s 

    union all 

    select 
        o.customer_id,
        o.ordered_at as event_timestamp,
        'Purchase' as event_type,
        o.total as event_value,
        true as led_to_purchase
    from orders o 

    union all 

    select 
        o.customer_id,
        o.ordered_at + interval '7 days' as event_timestamp --assume returns
        'Return' as event_type,
        false as led_to_purchase,
    from orders o 
    where o.returned = true
),

--add customer context and calculate days since signup
events_with_context as (
    select 
        e.customer_id,
        c.signed_up_at,
        e.event_timestamp,
        e.event_type,
        e.event_value,
        e.led_to_purchase,

        --days since signup
        datediff('day', c.signed_up_at, e.event_timestamp) as days_since_signup,

        --weeks since signup
        floor(datediff('day', c.signed_up_at, e.event_timestamp) / 7) as weeks_since_signup,

        --event sequence number
        row_number() over(partition by e.customer_id order by e.event_timestamp) as event_sequence,

        --cluster info
        cl.cluster_name,
        cl.persona_hidden
    from all_events e 
    inner join customers c on e.customer_id = c.customer_id
    inner join clusters cl on e.customer_id = cl.customer_id
),

--create journey timeline string
journey_timeline as (
    select 
        customer_id,
        cluster_name,
        persona_hidden,
        signed_up_at,

        --journey milestones
        min(case when event_type = 'Session' then event_timestamp end) as first_session,
        min(case when event_type = 'Purchase' then event_timestamp end) as first_purchase,
        min(case when event_type = 'Return' then event_timestamp end) as first_return,

        --days to milestones
        min(case when event_type = 'Session' then days_since_signup end) as days_to_first_session,
        min(case when event_type = 'Purchase' then days_since_signup end) as days_to_first_purchase,
        min(case when event_type = 'Return' then days_since_signup end) as days_to_first_return,

        --event counts by week
        count(case when weeks_since_signup = 0 then 1 end) as week_0_events
        count(case when weeks_since_signup = 1 then 1 end) as week_1_events,
        count(case when weeks_since_signup = 2 then 1 end) as week_2_events,
        count(case when weeks_since_signup = 3 then 1 end) as week_3_events,
        count(case when weeks_since_signup = 4 then 1 end) as week_4_events,

        --purchase counts by week
        count(case when weeks_since_signup = 0 and event_type = 'Purchase' then 1 end) as week_0_purchases,
        count(case when weeks_since_signup = 1 and event_type = 'Purchase' then 1 end) as week_1_purchases,
        count(case when weeks_since_signup = 2 and event_type = 'Purchase' then 1 end) as week_2_purchases,
        count(case when weeks_since_signup = 3 and event_type = 'Purchase' then 1 end) as week_3_purchases,
        count(case when weeks_since_signup = 4 and event_type = 'Purchase' then 1 end) as week_4_purchases
    from events_with_context
    group by customer_id, cluster_name, persona_hidden, signed_up_at
),

--sample journey strings (first 30 days)
journey_strings as (
    select 
        customer_id,
        cluster_name,
        string_agg(
            event_type ||
            case 
                when event_type = 'Purchase' then ' ($' || round(event_value, 0) || ')'
                when event_type = 'Session' then ' (' || round(event_value, 0) || ' views'
                else ''
            end ||
            ' [Day ' || days_since_signup || ']',
            ' -> '
            order by event_timestamp 
        ) as journey_path
    from events_with_context 
    where days_since_signup <= 30 --want 1st 30 days only
    group by customer_id, cluster_name
)

--combining everything
select 
    jt.*,
    js.journey_path
from journey_timeline jt 
left join journey_strings js on jt.customer_id = js.customer_id
    );
  
  
